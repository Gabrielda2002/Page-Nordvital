---
import { Mail, MessageCircle } from "lucide-react";

const contactLinks = [
  {
    href: "https://api.whatsapp.com/send?phone=573174309873&text=Hola sean bienvenidos a Nordvital ips, una ips comprometida con sus usuarios.",
    icon: MessageCircle,
    text: "(+57) 317-430-9873",
  },
  {
    href: "mailto:servicioalcliente@nordvitalips.com",
    icon: Mail,
    text: "servicioalcliente@nordvitalips.com",
  },
  {
    href: "/aboutus/headquarters",
    icon: Mail,
    text: "Nuestras sedes",
  },
];
---

<div>
  <h3 class="text-nv-azul-oscuro font-bold text-lg mb-4">
    Contáctanos
  </h3>
  <div class="space-y-3">
    {contactLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        class="flex items-center gap-2 text-sm text-gray-600 hover:text-nv-verde-salud transition-colors duration-300 group"
      >
        <link.icon className="w-4 h-4 shrink-0 text-nv-verde-salud opacity-70 group-hover:opacity-100 transition-opacity duration-300" />
        <span class="group-hover:translate-x-0.5 transition-transform duration-300">{link.text}</span>
      </a>
    ))}
  </div>
</div>