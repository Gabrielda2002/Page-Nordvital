---
import medicalIcon from "../assets/icons_header/stethoscope.svg?raw";
import helpIcon from "../assets/icons_header/help-octagon.svg?raw";
import blogIcon from "../assets/icons_header/article.svg?raw";
import homeIcon from "../assets/icons_header/home.svg?raw";

interface FooterInfoItem {
  label: string;
  href: string;
  icon: string;
}

const FOOTER_INFO_DATA: FooterInfoItem[] = [
  { label: "Inicio", href: "/", icon: homeIcon },
  { label: "Trabaja con nosotros", href: "/contact-us", icon: helpIcon },
  { label: "Edúcate", href: "/users/blog", icon: blogIcon },
  { label: "PQRSFD", href: "/users/pqrsfd", icon: helpIcon },
  { label: "Sarlaf y Sicof", href: "/aboutus/sarlaf-sicof", icon: helpIcon },
  { label: "Procedimientos Médicos", href: "/users/medical-procedures", icon: medicalIcon },
];
---

<div>
  <h3 class="text-nv-azul-oscuro font-bold text-lg mb-4">
    Información
  </h3>
  <div class="grid grid-cols-2 gap-y-2.5">
    {FOOTER_INFO_DATA.map((item) => (
      <a
        href={item.href}
        class="flex items-center gap-2 text-sm text-gray-600 hover:text-nv-verde-salud transition-colors duration-300 group"
      >
        <span set:html={item.icon} class="inline-flex items-center justify-center w-4 h-4 shrink-0 text-nv-verde-salud opacity-70 group-hover:opacity-100 transition-opacity duration-300 [&>svg]:w-full [&>svg]:h-full" />
        <span class="group-hover:translate-x-0.5 transition-transform duration-300">{item.label}</span>
      </a>
    ))}
  </div>
</div>
