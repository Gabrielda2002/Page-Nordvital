---
const phoneNumber = "+573174309873";
const whatsappMessage = "Hola sean bienvenidos a Nordvital ips, una ips comprometida con sus usuarios.";

import { Image } from 'astro:assets'

import NavLinks from "./NavLinks.astro";
import SocialLinks from "./SocialLinksHeader.astro";
// imgs
import iconPhone from "@/assets/icons_header/social-media/Phone.svg?raw";
import iconNordvital from "@/assets/icons_header/Nordvital-icon.svg?raw";
import menuIcon from "@/assets/icons_header/menu-2.svg?url";

---

<header class="bg-linear-to-r from-nv-verde-salud to-[#0a8f89] font-quicksand text-white font-semibold shadow-lg">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between py-2 lg:py-0">

      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0" aria-label="Inicio">
        <div set:html={iconNordvital} class="w-20 lg:w-36 brightness-0 invert" />
      </a>

      <!-- NavLinks + phone + social (desktop inline, mobile overlay) -->
      <div id="menu_movil" class="lg:flex lg:flex-1 lg:items-center lg:justify-between lg:ml-6 fixed lg:relative inset-0 lg:inset-auto bg-nv-verde-salud lg:bg-transparent z-50 lg:z-auto overflow-y-auto lg:overflow-visible flex-col lg:flex-row">
        <!-- Mobile: header bar with logo + close -->
        <div class="flex items-center justify-between p-4 border-b border-white/10 lg:hidden w-full">
          <a href="/" aria-label="Inicio">
            <div set:html={iconNordvital} class="w-28 brightness-0 invert" />
          </a>
          <button
            id="close_menu"
            class="p-2 hover:bg-white/15 rounded-lg transition-colors"
            aria-label="Cerrar menu"
          >
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- NavLinks -->
        <div class="flex-1 md:flex items-center justify-start md:justify-center ">
          <NavLinks />
        </div>  

        <!-- Phone + Social (desktop) -->
        <div class="flex items-center gap-3 p-4 lg:p-0">
          <a
            href={`https://api.whatsapp.com/send?phone=${phoneNumber}&text=${whatsappMessage}`}
            target="_blank"
            class="flex items-center gap-1.5 px-2 py-1.5 rounded-lg hover:bg-white/15 transition-colors duration-300 group"
          >
            <div set:html={iconPhone} class="w-5 h-5 group-hover:scale-110 transition-transform duration-300" />
            <span class="text-sm text-white/90 group-hover:text-white transition-colors duration-300">
              {phoneNumber}
            </span>
          </a>
          <div class="hidden lg:block">
            <SocialLinks />
          </div>
        </div>
      </div>

      <!-- Mobile menu button (outside overlay) -->
      <button
        id="button_movil"
        class="lg:hidden p-2 hover:bg-white/15 rounded-lg transition-colors ml-auto"
        aria-label="Abrir menu"
      >
        <img src={menuIcon} alt="Menu" class="w-6 h-6 brightness-0 invert" />
      </button>
    </div>
  </div>
</header>

<script>
  const menuButton = document.getElementById("button_movil");
  const menuMovil = document.getElementById("menu_movil");
  const body = document.body;

  menuButton?.addEventListener("click", () => {
    menuMovil?.classList.toggle("menu-open");
    body.style.overflow = menuMovil?.classList.contains("menu-open") ? "hidden" : "auto";
  });

  const closeMenu = document.getElementById("close_menu");
  closeMenu?.addEventListener("click", () => {
    menuMovil?.classList.remove("menu-open");
    body.style.overflow = "auto";
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 1024) {
      menuMovil?.classList.remove("menu-open");
      body.style.overflow = "auto";
    }
  });

  const submenuBtn = document.querySelectorAll(".submenu-btn");

  submenuBtn.forEach((btn) => {
    btn.addEventListener("click", (event) => {
      event.stopPropagation();
      const submenuId = btn.getAttribute("data-submenu");
      const submenu = document.getElementById(submenuId as string);
      const arrow = btn.querySelector(".arrow-icon");

      // Cerrar otros submenús
      document.querySelectorAll(".submenu").forEach((menu) => {
        if (menu.id !== submenuId) {
          menu.classList.remove("expanded");
          const otherArrow = document.querySelector(
            `[data-submenu="${menu.id}"] .arrow-icon`
          ) as HTMLElement;
          otherArrow?.style.setProperty("transform", "rotate(0deg)");
        }
      });

      // Toggle submenú actual
      submenu?.classList.toggle("expanded");
      arrow?.style.setProperty(
        "transform",
        submenu?.classList.contains("expanded") ? "rotate(180deg)" : "rotate(0deg)"
      );

      // Cerrar al hacer clic fuera (solo desktop)
      if (window.innerWidth >= 1025) {
        const closeHandler = (e: Event) => {
          if (!btn.contains(e.target as Node) && !submenu?.contains(e.target as Node)) {
            submenu?.classList.remove("expanded");
            arrow?.style.setProperty("transform", "rotate(0deg)");
            document.removeEventListener("click", closeHandler);
          }
        };
        setTimeout(() => document.addEventListener("click", closeHandler), 0);
      }
    });
  });
</script>

<style>
  /* ── Mobile overlay animation ── */
  #menu_movil {
    transform: translateX(100%);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.3s ease;
  }
  #menu_movil.menu-open {
    transform: translateX(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Desktop: no animation, always visible ── */
  @media (min-width: 1025px) {
    #menu_movil {
      transform: none;
      opacity: 1;
      pointer-events: auto;
    }
  }

  /* ── Arrow rotation for submenu buttons ── */
  .submenu-btn .arrow-icon {
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
</style>

