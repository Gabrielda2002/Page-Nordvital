---
interface CardProps {
  title: string;
  address: string;
  mapLink: string;
  images: ImageMetadata[];
  latitude: number;
  longitude: number;
}

import { Image } from "astro:assets";
import MapExt from "./react_components/MapExt";
import Button from "@/components/common/Button.astro";

const props = Astro.props as CardProps;
const { title = "", address = "", mapLink = "", images = [], latitude, longitude } = props;

const locationIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`;
const mapIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M21 10c0 6-9 13-9 13s-9-7-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>`;
---

<article class="w-full max-w-6xl mx-auto px-4 py-6" data-aos="zoom-in" data-aos-duration="1000">
  <div class="relative group">
    <div class="absolute -inset-1 bg-gradient-to-r from-nv-verde-salud via-nv-turquesa to-nv-azul rounded-2xl blur opacity-20 group-hover:opacity-40 transition-opacity duration-500"></div>
    <div class="relative bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl overflow-hidden border border-white/50">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
        <div class="relative h-64 sm:h-80 lg:h-full min-h-100 group-img">
          <Image
            src={images[0]}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-img-hover:scale-105"
            alt={`Imagen principal de ${title}`}
            widths={[400, 640, 768, 1024, 1280]}
            sizes="(max-width: 1024px) 100vw, 50vw"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent group-img-hover:opacity-0 transition-opacity duration-300"></div>
          {
            images.length > 1 && (
              <div class="absolute bottom-4 left-4 right-4 flex gap-2">
                {images.slice(1, 3).map((image, index) => (
                  <div class="flex-1 h-20 sm:h-24 rounded-xl overflow-hidden border-2 border-white/30 shadow-lg hover:border-white/60 transition-all duration-300 hover:scale-105">
                    <Image
                      src={image}
                      class="w-full h-full object-cover"
                      alt={`Imagen ${index + 2} de ${title}`}
                      widths={[150, 200, 300]}
                      sizes="150px"
                    />
                  </div>
                ))}
              </div>
            )
          }
          <div class="absolute top-4 left-4 px-3 py-1.5 bg-nv-verde-salud/90 backdrop-blur-sm rounded-full text-white text-sm font-medium">
            Sede Principal
          </div>
        </div>

        <div class="flex flex-col">
          <div class="p-6 sm:p-8 shrink-0">
            <div class="flex items-start gap-4 mb-6">
              <div class="shrink-0 w-12 h-12 bg-gradient-to-br from-nv-verde-salud to-nv-turquesa rounded-xl flex items-center justify-center shadow-lg shadow-nv-verde-salud/30">
                <span class="text-white w-6 h-6" set:html={locationIcon} />
              </div>
              <div class="flex-1">
                <h3 class="text-2xl sm:text-3xl font-bold bg-gradient-to-r from-nv-verde-salud to-nv-turquesa bg-clip-text text-transparent mb-3">
                  {title}
                </h3>
                <div class="flex items-start gap-3 text-nv-gris">
                  <span class="w-5 h-5 shrink-0 mt-1 text-nv-turquesa" set:html={locationIcon} />
                  <span class="text-base">{address}</span>
                </div>
              </div>
            </div>

            <div class="flex flex-wrap gap-3 mb-6">
              <div class="flex items-center gap-2 px-4 py-2 bg-nv-verde-salud/10 rounded-xl border border-nv-verde-salud/20">
                <span class="w-2 h-2 rounded-full bg-nv-verde-salud animate-pulse"></span>
                <span class="text-sm font-medium text-nv-azul-oscuro">Habilitada</span>
              </div>
              <div class="flex items-center gap-2 px-4 py-2 bg-nv-turquesa/10 rounded-xl border border-nv-turquesa/20">
                <span class="w-2 h-2 rounded-full bg-nv-turquesa"></span>
                <span class="text-sm font-medium text-nv-azul-oscuro"> Atención disponible</span>
              </div>
            </div>

            <Button url={mapLink} variant="outline" target="_blank" customIcon={mapIcon}>
              Ver en Google Maps
            </Button>
          </div>

          <div class="flex-1 min-h-62.2 relative border-t border-gray-100">
            <div class="h-full w-full">
              <MapExt lng={longitude} lat={latitude} client:load />
            </div>
            <div class="absolute bottom-4 right-4 px-3 py-1.5 bg-white/90 backdrop-blur-sm rounded-lg shadow-md text-xs font-medium text-nv-azul-oscuro">
              📍 Ver ubicación completa
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  .group-img:hover .group-img-hover {
    transform: scale(1.05);
  }
  .group-img:hover .group-img-hover + div {
    opacity: 0;
  }
</style>