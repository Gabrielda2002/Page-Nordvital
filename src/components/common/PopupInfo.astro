---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  imageAlt: string;
  title: string;
  storageKey?: string;
  durationDays?: number;
  delayMs?: number;
}

const {
  image,
  imageAlt,
  title,
  storageKey = 'nv-popup-junta-2026',
  durationDays = 7,
  delayMs = 1500,
} = Astro.props;
---

<div
  id="popup-info"
  class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="popup-title"
  aria-hidden="true"
  data-storage-key={storageKey}
  data-duration-days={String(durationDays)}
  data-delay-ms={String(delayMs)}
>
  <!-- Backdrop -->
  <div
    id="popup-info-backdrop"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity duration-300 opacity-0 motion-reduce:transition-none"
  ></div>

  <!-- Card -->
  <div
    id="popup-info-card"
    class="relative bg-white rounded-2xl shadow-2xl max-w-md w-full max-h-[90vh] overflow-hidden flex flex-col transition-all duration-300 scale-95 opacity-0 motion-reduce:transition-none"
  >
    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
      <h2 id="popup-title" class="sr-only text-lg font-semibold text-gray-800">{title}</h2>
      <span aria-hidden="true"></span>
      <button
        id="popup-info-close"
        type="button"
        class="w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-600 transition-colors"
        aria-label="Cerrar"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Image -->
    <div class="relative flex-1 overflow-y-auto">
      <Image
        src={image}
        alt={imageAlt}
        class="w-full h-auto object-contain"
        widths={[400, 600, 800]}
        sizes="(min-width: 768px) 28rem, 90vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <!-- Footer -->
    <div class="px-4 py-3 border-t border-gray-100 flex items-center justify-between gap-3 bg-gray-50/50">
      <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer select-none font-quicksand">
        <input
          id="popup-info-checkbox"
          type="checkbox"
          class="w-4 h-4 rounded border-gray-300 text-nv-verde-salud focus:ring-nv-verde-salud cursor-pointer"
        />
        <span>No volver a mostrar</span>
      </label>
      <button
        id="popup-info-accept"
        type="button"
        class="px-4 py-2 rounded-lg bg-nv-verde-salud text-white text-sm font-semibold hover:bg-nv-verde-salud-dark transition-colors font-quicksand"
      >
        Entendido
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const popup = document.getElementById('popup-info');
    if (!popup) return;

    const backdrop = document.getElementById('popup-info-backdrop');
    const card = document.getElementById('popup-info-card');
    const closeBtn = document.getElementById('popup-info-close');
    const acceptBtn = document.getElementById('popup-info-accept');
    const checkbox = document.getElementById('popup-info-checkbox');
    const storageKey = popup.getAttribute('data-storage-key');
    const durationDays = parseInt(popup.getAttribute('data-duration-days') || '7', 10);
    const delayMs = parseInt(popup.getAttribute('data-delay-ms') || '1500', 10);

    function shouldShow() {
      try {
        const stored = localStorage.getItem(storageKey);
        if (!stored) return true;
        const expiry = parseInt(stored, 10);
        return Date.now() > expiry;
      } catch (e) {
        return true;
      }
    }

    function show() {
      if (!popup || !backdrop || !card) return;
      // No mostrar si el loader aún está visible
      if (document.getElementById('global-loader')) return;

      popup.classList.remove('hidden');
      popup.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();

      // Trigger animations
      requestAnimationFrame(() => {
        backdrop.classList.remove('opacity-0');
        card.classList.remove('opacity-0', 'scale-95');
      });
    }

    function hide(save) {
      if (!popup || !backdrop || !card) return;
      backdrop.classList.add('opacity-0');
      card.classList.add('opacity-0', 'scale-95');

      setTimeout(() => {
        popup.classList.add('hidden');
        popup.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }, 300);

      if (save && checkbox && checkbox.checked) {
        try {
          const expiry = Date.now() + (durationDays * 86400000);
          localStorage.setItem(storageKey, String(expiry));
        } catch (e) {
          // ignore
        }
      }
    }

    function onClose(save) {
      hide(save);
    }

    // Event listeners
    closeBtn?.addEventListener('click', function() {
      onClose(true);
    });
    acceptBtn?.addEventListener('click', function() {
      onClose(true);
    });
    backdrop?.addEventListener('click', function() {
      onClose(true);
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !popup.classList.contains('hidden')) {
        onClose(true);
      }
    });

    // Show after delay
    if (shouldShow()) {
      setTimeout(show, delayMs);
    }
  })();
</script>
