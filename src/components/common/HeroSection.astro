---
import { ChevronRight, Home } from 'lucide-react';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  subtitle?: string;
  backgroundImage: ImageMetadata;
  breadcrumb?: {
    label: string;
    link: string;
  }[];
  showTitle?: boolean;
}

const { title, subtitle, backgroundImage, breadcrumb, showTitle = true } = Astro.props;
const displayBreadcrumb = breadcrumb && breadcrumb.length > 0 ? breadcrumb : [];
---

<section 
  class="hero-section relative w-full overflow-hidden"
  role="banner"
  aria-label={`Sección ${title}`}
>
  <!-- Imagen de fondo con overlay gradiente -->
  <div class="hero-background absolute inset-0 z-0">
    <Image
      src={backgroundImage}
      alt={`Imagen de fondo para ${title}`}
      class="w-full h-full object-cover"
      widths={[300, 600, 900, 1200, 1800, 2400]}
      sizes={"(min-width: 1536px) 100vw, (min-width: 1280px) 100vw, (min-width: 1024px) 100vw, (min-width: 768px) 100vw, 100vw"}
      loading="eager"
      fetchpriority={"high"}
    />
    <div class="absolute inset-0 bg-linear-to-r from-nv-azul-oscuro/95 via-nv-azul-oscuro/70 to-nv-azul-oscuro/30"></div>
    <div class="absolute inset-0 bg-linear-to-t from-nv-azul-oscuro/60 via-transparent to-transparent"></div>
  </div>

  <!-- Elementos decorativos -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-nv-turquesa/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-nv-verde-salud/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

  <!-- Contenido principal -->
  <div class="hero-content relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16 lg:py-20">
    <div class="max-w-4xl">
      {displayBreadcrumb.length > 0 && (
        <nav 
          class="breadcrumb-nav mb-6 md:mb-8" 
          aria-label="Navegación de ruta"
        >
          <ol class="flex items-center gap-2 flex-wrap">
            {displayBreadcrumb.map((item, index) => (
              <li class="flex items-center gap-2">
                {index > 0 && (
                  <ChevronRight 
                    className="w-4 h-4 text-white/40" 
                    aria-hidden="true"
                  />
                )}
                <a
                  href={item.link}
                  class="breadcrumb-link group flex items-center gap-2 px-3 py-1.5 
                         text-sm md:text-base font-medium text-white/80 
                         hover:text-white rounded-lg 
                         hover:bg-white/10 backdrop-blur-sm
                         transition-all duration-300 ease-out
                         hover:scale-[1.02] hover:-translate-y-0.5
                         focus:outline-none focus:ring-2 focus:ring-nv-turquesa focus:ring-offset-2 focus:ring-offset-transparent"
                  aria-current={index === displayBreadcrumb.length - 1 ? 'page' : undefined}
                >
                  {index === 0 && (
                    <Home 
                      className="w-4 h-4 transition-transform duration-300 group-hover:scale-110" 
                      aria-hidden="true"
                    />
                  )}
                  <span class="transition-transform duration-300 group-hover:translate-x-0.5">
                    {item.label}
                  </span>
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <!-- Título y subtítulo con glassmorphism -->
      {showTitle && (
        <div class="hero-text-content backdrop-blur-xl bg-white/10 rounded-2xl p-6 md:p-8 lg:p-10 border border-white/20 shadow-xl shadow-nv-azul-oscuro/20" data-aos="fade-down" data-aos-duration="1000" data-aos-delay="200">
          <!-- Badge animado -->
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/15 backdrop-blur-md border border-white/25 mb-4 md:mb-6">
            <span class="w-2 h-2 rounded-full bg-nv-turquesa animate-pulse"></span>
            <span class="text-sm text-white/90 font-medium">NordVital IPS</span>
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-gnuolane font-bold text-white mb-3 md:mb-4">
            {title}
          </h1>
          
          {subtitle && (
            <p class="text-base md:text-lg lg:text-xl text-white/85 max-w-2xl font-quicksand leading-relaxed">
              {subtitle}
            </p>
          )}

          <!-- Línea decorativa -->
          <div class="mt-6 flex items-center gap-3">
            <div class="h-1 w-12 bg-nv-turquesa rounded-full"></div>
            <div class="h-1 w-8 bg-nv-verde-salud/60 rounded-full"></div>
            <div class="h-1 w-4 bg-nv-turquesa/30 rounded-full"></div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 280px;
    margin-bottom: 3rem;
    background-color: var(--color-nv-azul-oscuro, #31406D);
  }

  @media (min-width: 768px) {
    .hero-section {
      min-height: 350px;
    }
  }

  @media (min-width: 1024px) {
    .hero-section {
      min-height: 400px;
    }
  }

  /* Animación sutil para el fondo */
  .hero-background img {
    animation: subtle-zoom 20s ease-in-out infinite alternate;
  }

  @keyframes subtle-zoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.05);
    }
  }

  /* Mejora de accesibilidad */
  .breadcrumb-link:focus-visible {
    outline: 2px solid var(--color-nv-turquesa, #00B3A0);
    outline-offset: 2px;
  }

  /* Optimización para motion reducido */
  @media (prefers-reduced-motion: reduce) {
    .hero-background img,
    .breadcrumb-link,
    .breadcrumb-link * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
