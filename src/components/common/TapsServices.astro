---
import H from '../ui/H.astro';
import P from '../ui/P.astro';

interface TapProps {
    id: string;
    title: string;
    icon?: string;
}

interface props extends TapProps {}

const {title, content, icon, isActive = false} = Astro.props;

---

<div class=`  ${isActive ? 'block' : ''}`>

    <div class="flex items-center gap-4 p-4 cursor-pointer hover:bg-gray-100 rounded-lg">
        {icon && <img src={icon} alt={title} class="w-8 h-8" />}
        <H level={3} size="md" color="emphasis">{title}</H>
    </div>
    <div class="p-4">
        <P color="muted">{content}</P>
    </div>

</div>