---
import type { LucideIcon } from "lucide-react"
interface Props {
  tabs: {
    id: string;  
    title: string;
    icon?: LucideIcon | string;
  }[];
}

const { tabs } = Astro.props;
---

<div class="tabs-container w-full mx-auto my-4 p-5">
  <!-- Mobile: Accordion view (buttons only, content populated by JS) -->
  <div class="lg:hidden space-y-3">
    {tabs.map((tab, index) => (
      <div class="accordion-item rounded-lg overflow-hidden">
        <button
          data-accordion={tab.id}
          class="tab-button flex items-center gap-2 w-full p-4 cursor-pointer transition-all duration-300"
          class:list={[{ 'active': index === 0 }]}
          aria-expanded={index === 0 ? "true" : "false"}
        >
          {typeof tab.icon === "string" ? (
            <div set:html={tab.icon}></div>
          ) : tab.icon ? (
            <tab.icon className="w-5 h-5" />
          ) : null}
          <span class="flex-1 text-left">{tab.title}</span>
          <svg
            class="accordion-icon w-5 h-5 transition-transform duration-300"
            fill="white"
            stroke="white"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"
            ></path>
          </svg>
        </button>
        <div
          data-accordion-content={tab.id}
          class="accordion-panel max-h-0 overflow-hidden transition-all duration-300 ease-in-out"
        >
          <div class="p-4 bg-gray-200 rounded-b-lg accordion-content-slot">
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Desktop: Tabs view -->
  <div class="hidden lg:block">
    <div class="flex flex-col lg:flex-row justify-center gap-4 border-b">
      {tabs.map((tab, index) => (
        <button
          data-tab={tab.id}
          class="tab-button flex items-center gap-2 p-4 cursor-pointer rounded-t-lg transition-all duration-300"
          class:list={[{ 'active': index === 0 }]}
        >
          {typeof tab.icon === "string" ? (
            <div set:html={tab.icon}></div>
          ) : tab.icon ? (
            <tab.icon className="w-5 h-5" />
          ) : null}
          <span>{tab.title}</span>
        </button>
      ))}
    </div>

    <div class="tab-content flex items-center justify-center p-10 bg-gray-200 rounded-lg shadow-md border border-gray-400/30">
      <slot />
    </div>
  </div>
</div>

<script>
  const initTabs = () => {
    // Desktop tabs
    const desktopTabs = document.querySelectorAll('.tab-button[data-tab]');
    const tabContents = document.querySelectorAll('[data-tab-content]');
  
    if (desktopTabs.length && tabContents.length) {
      desktopTabs[0].classList.add('active');
      tabContents[0].classList.add('active');

      desktopTabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = (tab as HTMLElement).dataset.tab;
    
          desktopTabs.forEach(t => t.classList.remove('active'));
          tabContents.forEach(c => c.classList.remove('active'));
          
          tab.classList.add('active');
          document.querySelector(`[data-tab-content="${target}"]`)?.classList.add('active');
        });
      });
    }

    // Mobile accordion - clone content from desktop tab-content into accordion panels
    const accordionPanels = document.querySelectorAll('[data-accordion-content]');
    
    accordionPanels.forEach(panel => {
      const panelId = (panel as HTMLElement).dataset.accordionContent;
      const matchingContent = document.querySelector(`[data-tab-content="${panelId}"]`);
      const innerDiv = panel.querySelector('.accordion-content-slot');
      if (matchingContent && innerDiv) {
        innerDiv.innerHTML = (matchingContent as HTMLElement).innerHTML;
      }
    });

    // Setup accordion interactions
    const accordionButtons = document.querySelectorAll('[data-accordion]');
    
    if (accordionButtons.length) {
      // Open first accordion by default
      const firstBtn = accordionButtons[0] as HTMLElement;
      const firstPanel = document.querySelector(`[data-accordion-content="${firstBtn.dataset.accordion}"]`) as HTMLElement;
      if (firstPanel) {
        firstPanel.style.maxHeight = `${firstPanel.scrollHeight}px`;
        const firstIcon = firstBtn.querySelector('.accordion-icon') as SVGElement;
        if (firstIcon) firstIcon.style.transform = 'rotate(180deg)';
      }

      accordionButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const target = (btn as HTMLElement).dataset.accordion;
          const panel = document.querySelector(`[data-accordion-content="${target}"]`) as HTMLElement;
          const icon = btn.querySelector('.accordion-icon') as SVGElement;
          
          if (!panel || !icon) return;

          const isExpanded = btn.getAttribute('aria-expanded') === 'true';

          if (!isExpanded) {
            panel.style.maxHeight = `${panel.scrollHeight}px`;
            icon.style.transform = 'rotate(180deg)';
            btn.setAttribute('aria-expanded', 'true');
          } else {
            panel.style.maxHeight = '0';
            icon.style.transform = 'rotate(0)';
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initTabs);
</script>

<style>
  /* Tab inactivo - Gris claro */
  .tab-button {
    background-color: #e2e8f0;
    color: #64748b;
    font-weight: 500;
  }

  /* Hover en tab inactivo */
  .tab-button:hover:not(.active) {
    background-color: #cbd5e1;
    color: #475569;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    border-bottom: 4px solid #0d9488;
  }

  /* Tab ACTIVO - Verde/Teal brillante */
  .tab-button.active {
    background-color: #0d9488;
    color: white;
    font-weight: 600;
    box-shadow: 0 4px 12px rgba(13, 148, 136, 0.4);
  }

  /* Solo desktop: tabs con transform */
  @media (min-width: 1024px) {
    .tab-button.active {
      transform: translateY(-5px);
    }
  }

  :global([data-tab-content]) {
    display: none;
  }
  :global([data-tab-content].active) {
    display: block;
  }
</style>  
