---
import ContactLinks from "./ContactUsFooter.astro";
import SocialLinks from "./SocialLinksFooter.astro";
import FooterInfo from "./FooterInfo.astro";

import logoNordvital from "../assets/icons_header/Nordvital-icon.svg?raw";
---

<footer class="font-quicksand">
  <div class="h-1 bg-linear-to-r from-nv-verde-salud to-nv-turquesa"></div>

  <div class="bg-gray-50 text-gray-700">
    <div class="container mx-auto px-6 py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <div class="flex items-center justify-center">
        <div set:html={logoNordvital} class="w-28 h-28 sm:w-32 sm:h-32 lg:w-40 lg:h-40" />
      </div>
      <FooterInfo />
      <ContactLinks />
      <SocialLinks />
    </div>
  </div>

  <div class="bg-white border-t border-gray-100">
    <div class="container mx-auto px-6 py-6 text-center text-sm text-gray-500 font-medium">
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-3">
        <a href="/our-policies" class="hover:text-nv-verde-salud transition-colors duration-300">Términos y condiciones</a>
        <a href="/data-policy" class="hover:text-nv-verde-salud transition-colors duration-300">Tratamiento de datos</a>
      </div>
      <p>Nordvital IPS &mdash; Todos los derechos reservados &copy; {new Date().getFullYear()}</p>
    </div>
  </div>
</footer>
