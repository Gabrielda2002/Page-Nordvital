---
export interface Props {
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  size?: "sm" | "md" | "lg" | "xl" | "2xl" | "3xl" | "4xl";
  color?: "primary" | "secondary" | "accent" | "cta" | "emphasis" | "muted" | "white" | "foreground";
  align?: "left" | "center" | "right";
  class?: string;
}

const {
  level = 2,
  size = "lg",
  color = "primary",
  align = "left",
  class: className = "",
} = Astro.props;

const sizeClasses = {
  sm: "text-lg md:text-xl",
  md: "text-xl md:text-2xl",
  lg: "text-2xl md:text-3xl",
  xl: "text-3xl md:text-4xl",
  "2xl": "text-4xl md:text-5xl",
  "3xl": "text-4xl md:text-5xl lg:text-6xl",
  "4xl": "text-5xl md:text-6xl lg:text-7xl",
};

const colorClasses = {
  primary: "text-nv-verde-salud",
  secondary: "text-nv-turquesa",
  accent: "text-nv-azul",
  cta: "text-nv-rojo-cta",
  emphasis: "text-nv-azul-oscuro",
  muted: "text-nv-gris",
  white: "text-white",
  foreground: "text-foreground",
};

const alignClasses = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};

const classes = [
  "font-bold",
  "font-gnuolane",
  sizeClasses[size],
  colorClasses[color],
  alignClasses[align],
  className,
]
  .filter(Boolean)
  .join(" ");

const Tag = `h${level}` as keyof HTMLElementTagNameMap;
---

<Tag class={classes}>
  <slot />
</Tag>