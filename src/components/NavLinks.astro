---
import iconRow from "../assets/flecha.svg?raw";

import aboutusIcon from "../assets/icons_header/users.svg?raw";
import headquartersIcon from "../assets/icons_header/building-community.svg?raw";
import contractsIcon from "../assets/icons_header/contract.svg?raw";
import statusIcon from "../assets/icons_header/coins.svg?raw";
import helpIcon from "../assets/icons_header/help-octagon.svg?raw";
import rightIcon from "../assets/icons_header/gavel.svg?raw";
import resultIcon from "../assets/icons_header/report-analytics.svg?raw";
import blogIcon from "../assets/icons_header/article.svg?raw";
import educativeIcon from "../assets/icons_header/school.svg?raw";
import medicalIcon from "../assets/icons_header/stethoscope.svg?raw";

const navItems = [
  {
    label: "Nosotros",
    submenuId: "nosotros",
    items: [
      { href: "/aboutus/aboutus", icon: aboutusIcon, label: "Quienes somos" },
      { href: "/aboutus/headquarters", icon: headquartersIcon, label: "Nuestras sedes" },
      { href: "/aboutus/agreement", icon: contractsIcon, label: "Convenios" },
      { href: "/aboutus/status-financiero", icon: statusIcon, label: "Estados financieros" },
      { href: "/aboutus/sarlaf-sicof", icon: helpIcon, label: "Sarlaf y Sicof" },
    ],
  },
  { label: "Servicios", href: "/services" },
  {
    label: "Usuarios",
    submenuId: "usuarios",
    items: [
      { href: "/users/pqrsfd", icon: helpIcon, label: "PQRSFD" },
      { href: "/users/association", icon: statusIcon, label: "Asociación de usuarios" },
      { href: "/users/rights-duties", icon: rightIcon, label: "Derechos y deberes" },
      { href: "/users/blog", icon: blogIcon, label: "Nuestro blog" },
      { href: "/users/laboratorios", icon: resultIcon, label: "Resultado laboratorio" },
      { href: "/users/medical-procedures", icon: medicalIcon, label: "Procedimientos Médicos" },
      { href: "/users/seminar", icon: educativeIcon, label: "Seminario" },
    ],
  },
  { label: "Contáctenos", href: "/contact-us" },
];
---

<nav class="relative h-full lg:h-auto">
  <ul class="flex flex-col lg:flex-row lg:space-x-4 xl:space-x-8 space-y-2 lg:space-y-0 p-4 lg:p-0 w-full justify-between">
    {navItems.map((item) => (
      <li class:list={["relative", { "": item.submenuId }]}>
        {item.submenuId ? (
          <>
            <button
              class="submenu-btn cursor-pointer flex items-center w-full justify-between py-2 px-3 group hover:bg-white/15 rounded-lg transition-colors duration-300"
              data-submenu={item.submenuId}
            >
              <span class="group-hover:text-white transition-colors duration-300">
                {item.label}
              </span>
              <div
                set:html={iconRow}
                class="p-1 flex items-center transition-transform group-hover:text-white duration-300 ease-in-out arrow-icon"
              />
            </button>
            <ul
              class="submenu absolute w-full lg:w-125 lg:-ml-4 font-normal z-50 rounded-md shadow-lg top-full overflow-hidden"
              id={item.submenuId}
            >
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 p-2 lg:p-4">
                {item.items?.map((sub) => (
                    <li class="relative border hover:bg-gray-200 hover:text-teal-500 rounded-md transition-colors whitespace-normal break-words">
                    <a href={sub.href} class="flex items-center gap-2 p-3">
                      <div set:html={sub.icon} class="w-5 h-5 shrink-0" />
                      <span class="text-balance">{sub.label}</span>
                    </a>
                  </li>
                ))}
              </div>
            </ul>
          </>
        ) : (
          <a
            href={item.href}
            class="flex items-center rounded-lg hover:bg-white/15 py-2 px-3 group hover:text-white transition-colors duration-300"
          >
            <span class="group-hover:text-white transition-colors duration-300">
              {item.label}
            </span>
          </a>
        )}
      </li>
    ))}
  </ul>
</nav>

<style>
  .submenu {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    background: var(--color-gray-50, #f9fafb);
    color: var(--color-gray-900, #111827);
    transition:
      max-height 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.3s ease,
      transform 0.3s ease;
  }
  .submenu.expanded {
    max-height: 700px;
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 1025px) {
    .submenu {
      max-height: none;
      overflow: visible;
      transform: translateY(-6px);
    }
    .submenu.expanded {
      transform: translateY(0);
    }
  }

  @media (min-width: 1024px) and (max-width: 1530px) {
    nav { width: 100%; }
    nav > ul { position: relative; display: flex; justify-content: space-between; width: 100%; }
    nav > ul > li { position: static; white-space: nowrap; }
    .submenu {
      position: absolute;
      width: auto !important;
      min-width: 280px;
      max-width: min(90vw, 400px);
    }
    #nosotros { left: 0; right: auto; }
    #usuarios { left: auto; right: 0; }
  }

  @media (max-width: 1024px) {
    .submenu {
      position: relative;
      background: transparent;
      color: rgba(255, 255, 255, 0.9);
    }
    .submenu > div {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 0.5rem;
    }
    .submenu > div > li {
      border-color: rgba(255, 255, 255, 0.15);
    }
    .submenu > div > li a {
      color: rgba(255, 255, 255, 0.9);
    }
    .submenu > div > li:hover {
      background: rgba(255, 255, 255, 0.15);
    }
    .submenu > div > li:hover a {
      color: #fff;
    }
  }
</style>
