---
import Layout from "../layouts/Layout.astro";
import HeroSection from "@/components/common/HeroSection.astro";
import img from "@/images/Header/CONTACTO_11zon.webp";
import MessageFormCotactUs from "@/components/react_components/MessageFormContactUs";
import WorkUsForm from "@/components/react_components/WorkUsForm";

//icons
import H from "@/components/ui/H.astro";
import { Clock, Mail, Map, MapPin, Phone } from "lucide-react";
import P from "@/components/ui/P.astro";
---

<Layout
  title="Contacto | Nordvital IPS - Atención y Soporte"
  description="Contáctanos para resolver dudas, agendar citas o unirte a nuestro equipo. Nordvital IPS ofrece atención personalizada a través de nuestras líneas telefónicas, correo y chat de servicio."
>
  <head>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
      rel="stylesheet"
    />
  </head>

  <main class="overflow-x-hidden bg-gray-100">
    <HeroSection title="Contáctenos" backgroundImage={img} breadcrumb={[
      { label: "Inicio", link: "/" },
      { label: "Contáctenos", link: "/contact-us" }
    ]} />

    <div class="container mx-auto px-4 py-2">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Info Cards Section -->
        <div class="w-full lg:w-1/2" data-aos="fade-right" data-aos-duration="1000">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <!-- Sede Administrativa -->
            <div
              class="group p-6 bg-white rounded-xl shadow-md border border-slate-200 hover:border-nv-turquesa hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            >
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-nv-turquesa/10 mb-4 group-hover:bg-nv-turquesa/20 transition-colors">
                <MapPin className="h-6 w-6 text-nv-turquesa" />
              </div>
              <H level={5} size="md" color="emphasis">Sede Administrativa</H>
              <div class="flex items-center gap-2 mt-3">
                <Map className="h-4 w-4 text-nv-turquesa shrink-0" />
                <a
                  href="https://maps.app.goo.gl/KLWrQo7caN8dcdpZ6"
                  target="_blank"
                  class="text-sm font-medium text-nv-azul-claro transition-colors duration-300 underline underline-offset-2 hover:text-nv-azul-claro-dark"
                >
                  Ver ubicación en Google Maps
                </a>
              </div>
            </div>

            <!-- Correo Electrónico -->
            <div
              class="group p-6 bg-white rounded-xl shadow-md border border-slate-200 hover:border-nv-turquesa hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            >
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-nv-turquesa/10 mb-4 group-hover:bg-nv-turquesa/20 transition-colors">
                <Mail className="h-6 w-6 text-nv-turquesa" />
              </div>
              <H level={5} size="md" color="emphasis">Correo Electrónico</H>
              <div class="mt-3 space-y-3">
                <div>
                  <P size="sm">Para gestión de servicios:</P>
                  <a
                    href="mailto:servicioalcliente@nordvitalips.com"
                    class="text-sm text-nv-azul-claro hover:text-nv-azul-claro-dark transition-colors duration-300 underline underline-offset-2 break-all"
                  >
                    servicioalcliente@nordvitalips.com
                  </a>
                </div>
                <div>
                  <P size="sm">Para gestión jurídica:</P>
                  <a
                    href="mailto:notificacionesjudiciales@nordvitalips.com"
                    class="text-sm text-nv-azul-claro hover:text-nv-azul-claro-dark transition-colors duration-300 underline underline-offset-2 break-all"
                  >
                    notificacionesjudiciales@nordvitalips.com
                  </a>
                </div>
              </div>
            </div>

            <!-- Contacto -->
            <div
              class="group p-6 bg-white rounded-xl shadow-md border border-slate-200 hover:border-nv-turquesa hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            >
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-nv-turquesa/10 mb-4 group-hover:bg-nv-turquesa/20 transition-colors">
                <Phone className="h-6 w-6 text-nv-turquesa" />
              </div>
              <H level={5} size="md" color="emphasis">Contacto</H>
              <div class="mt-3 flex items-center gap-2">
                <Phone className="h-4 w-4 text-nv-turquesa shrink-0" />
                <a
                  href="tel:+573174309873"
                  class="text-lg font-semibold text-nv-azul-oscuro hover:text-nv-turquesa transition-colors duration-300"
                >
                  (+57) 3174309873
                </a>
              </div>
            </div>

            <!-- Horarios de Atención -->
            <div
              class="group p-6 bg-white rounded-xl shadow-md border border-slate-200 hover:border-nv-turquesa hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
            >
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-nv-turquesa/10 mb-4 group-hover:bg-nv-turquesa/20 transition-colors">
                <Clock className="h-6 w-6 text-nv-turquesa" />
              </div>
              <H level={5} size="md" color="emphasis">Horarios De Atención</H>
              <div class="mt-3 space-y-3">
                <div class="flex items-center justify-between">
                  <span class="text-sm font-quicksand font-semibold text-nv-azul-oscuro">Lunes a viernes</span>
                  <span class="text-sm font-quicksand text-gray-600">6:00 am - 6:30 pm</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-sm font-quicksand font-semibold text-nv-azul-oscuro">Sábados</span>
                  <span class="text-sm font-quicksand text-gray-600">8:00 am - 12:00 pm</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div
          class="w-full lg:w-1/2 bg-white rounded-xl shadow-lg border border-slate-200 mb-20"
          data-aos="fade-left"
          data-aos-duration="1000"
          data-aos-delay="150"
        >
          <div class="p-6 border-b">
            <div class="flex flex-col sm:flex-row gap-4">
              <button
                class="w-full sm:w-auto px-4 py-2 rounded-xl text-white bg-gray-500 hover:bg-gray-600 transition-colors"
                id="contactanos-btn"
              >
                Escribe un mensaje
              </button>
              <button
                class="w-full sm:w-auto px-4 py-2 rounded-xl text-white bg-gray-500 hover:bg-gray-600 transition-colors"
                id="escribe-mensaje-btn"
              >
                Trabaje con Nosotros
              </button>
              <button
                class="w-full sm:w-auto px-4 py-2 rounded-xl text-white bg-gray-500 hover:bg-gray-600 transition-colors"
                id="pqrsfd-btn"
              >
                PQRSFD
              </button>
              
            </div>
          </div>

          <div id="form-contacto" class="p-3">
            <MessageFormCotactUs client:load />
          </div>

          <div id="form-puesto-trabajo" class="p-3">
            <WorkUsForm client:load />
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const contactanosBtn = document.getElementById("contactanos-btn");
      const escribeMensajeBtn = document.getElementById("escribe-mensaje-btn");
      const pqrsfdBtn = document.getElementById("pqrsfd-btn");

      // llevar al usuario al formulario de PQRSFD
      pqrsfdBtn?.addEventListener("click", function () {
        window.location.href = "/users/pqrsfd#pqrsfd-form";
      });

      const formContacto = document.getElementById("form-contacto");
      const formPuestoTrabajo = document.getElementById("form-puesto-trabajo");

      // button
      const updateButtonStyles = (
        activeBtn: HTMLElement,
        inactiveBtn: HTMLElement
      ) => {
        // Activar
        activeBtn.classList.remove("bg-gray-500");
        activeBtn.classList.add("bg-sky-500");
        // Inactivar styles button
        inactiveBtn.classList.remove("bg-sky-500");
        inactiveBtn.classList.add("bg-gray-500");
      };

      // inicial
      if (
        formContacto &&
        formPuestoTrabajo &&
        contactanosBtn &&
        escribeMensajeBtn
      ) {
        formContacto.style.display = "none";
        formPuestoTrabajo.style.display = "block";
        updateButtonStyles(contactanosBtn, escribeMensajeBtn);

        // "Escribe un mensaje" button
        contactanosBtn.addEventListener("click", function () {
          formContacto.style.display = "block";
          formPuestoTrabajo.style.display = "none";
          updateButtonStyles(contactanosBtn, escribeMensajeBtn);
        });

        // "Trabaje con Nosotros" button
        escribeMensajeBtn.addEventListener("click", function () {
          formContacto.style.display = "none";
          formPuestoTrabajo.style.display = "block";
          updateButtonStyles(escribeMensajeBtn, contactanosBtn);
        });
      }
      if (escribeMensajeBtn && contactanosBtn) {
        updateButtonStyles(escribeMensajeBtn, contactanosBtn);
      }
    });
  </script>
</Layout>
