---
import Layout from "../../layouts/Layout.astro";
import HeroSection from "@/components/common/HeroSection.astro";
import H from "@/components/ui/H.astro";
import P from "@/components/ui/P.astro";
import img from "@/images/Header/USUARIOS_11zon.webp";

///images
import modal1 from "@/images/Usuarios/Modales/Ecografia de seno.jpeg?url";
import modal2 from "@/images/Usuarios/Modales/Ecografia de transrectal.jpeg?url";
import modal3 from "@/images/Usuarios/Modales/Ecografia de prostata transabdominal.jpeg?url";
import modal4 from "@/images/Usuarios/Modales/Ecografia de abdomen superior.jpeg?url";
import modal5 from "@/images/Usuarios/Modales/Ecografia vias urinarias.jpeg?url";
import modal6 from "@/images/Usuarios/Modales/Ecografia Pelvica.jpeg?url";
import modal7 from "@/images/Usuarios/Modales/Ecografia abdomen total.jpeg?url";
import modal8 from "@/images/Usuarios/Modales/Ecografia obstreticas.jpeg?url";
import modal9 from "@/images/Usuarios/Modales/tomografias.jpeg?url";
import modal10 from "@/images/Usuarios/Modales/imagenologia.jpeg?url";
import modal11 from "@/images/Usuarios/Modales/citologia.jpeg?url";
import modal12 from "@/images/Usuarios/Modales/lavado oidos.jpeg?url";
import modal13 from "@/images/Usuarios/Modales/prueba esfuerzo.jpeg?url";
import modal14 from "@/images/Usuarios/Modales/ecocardiograma.jpeg?url";
import modal15 from "@/images/Usuarios/Modales/holter.jpeg?url";
import modal16 from "@/images/Usuarios/Modales/colposcopia.jpeg?url";
import modal17 from "@/images/Usuarios/Modales/Electrocardiograma.jpeg?url";

///icons
import icon from "@/images/Usuarios/Modales/icon.svg";
---

<Layout title="Procedimientos Médicos | Nordvital IPS - Guías" description="Guías detalladas para procedimientos médicos en Nordvital IPS: ecografías, tomografías, electrocardiogramas, colposcopia y más.">
  <head>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
      rel="stylesheet"
    />
  </head>

  <main class="overflow-x-hidden bg-gray-100">
    <HeroSection title="Procedimientos Médicos" backgroundImage={img} breadcrumb={[
      { label: "Inicio", link: "/" },
      { label: "Procedimientos Médicos", link: "/users/medical-procedures" }
    ]} />

    <div
      class="w-[90%] md:w-2/3 flex mx-auto items-center justify-cente text-gray-600"
    >
      <div class="conttres">
        <div class="flex items-center cont-medicina contCuatro">
          <img src={icon.src} alt="" class="h-11" />

          <H level={6} size="lg" color="emphasis" class="ml-2"><em>Procedimientos Médicos</em></H>
        </div>

        <div class="medicina mt-6 mb-2">
          <H level={2} size="md" class="mb-2">
            Guía para Realizar Procedimientos médicos según su tratamiento
          </H>
          <P>
            Para facilitar el correcto procedimiento a los diferentes exámenes,
            hemos creado una guía que explica detalladamente cómo realizar los
            distintos exámenes de laboratorio. Para visualizar el documento siga
            el paso a paso descrito a continuación.
          </P><br />
          <H level={5} size="md">
            Pasos para visualizar las imagenes:
          </H>
          <ul class="p-2">
            <li>
              1. Haga clic en el enlace que se encuentra a continuación.
            </li>
            <li>
              2. Lea y visualice detenidamente todos los pasos para que haga
              uso del correcto procedimiento.
            </li>
            <li>
              3. Cada imagen tiene la opción de poder salir de la misma por
              fuera de esta.
            </li>
          </ul>
          <br />
        </div>

        <div id="misionVisionModal" class="inset-0 z-50">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
            <div class="modal-body mv__contenido space-y-4">
              <H level={5} size="md">Ecografías:</H>
              <ul class="space-y-2 m-5 list-disc">
                <li>
                  <a href={modal1} class="text-blue-600 hover:underline"
                    >Ecografía de Mama o de Seno</a
                  >
                </li>
                <li>
                  <a href={modal2} class="text-blue-600 hover:underline"
                    >Ecografía de Próstata Transrectal</a
                  >
                </li>
                <li>
                  <a href={modal3} class="text-blue-600 hover:underline"
                    >Ecografía de Próstata Transabdominal</a
                  >
                </li>
                <li>
                  <a href={modal4} class="text-blue-600 hover:underline"
                    >Ecografía de Abdomen Superior y Ecografía Hepatobiliar</a
                  >
                </li>
                <li>
                  <a href={modal5} class="text-blue-600 hover:underline"
                    >Ecografía de Vías Urinarias</a
                  >
                </li>
                <li>
                  <a href={modal6} class="text-blue-600 hover:underline"
                    >Ecografía Pélvica Trasabdominal</a
                  >
                </li>
                <li>
                  <a href={modal7} class="text-blue-600 hover:underline"
                    >Ecografía de Abdomen Total</a
                  >
                </li>
                <li>
                  <a href={modal8} class="text-blue-600 hover:underline"
                    >Ecografías Obstétricas y Ginecológicas</a
                  >
                </li>
              </ul>
            </div>

            <div class="space-y-4">
              <H level={5} size="md">Tomografías:</H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal9} class="text-blue-600 hover:underline"
                    >Tomografía y Urografía excretora</a
                  >
                </li>
              </ul>

              <H level={5} size="md">Imagenología:</H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal10} class="text-blue-600 hover:underline"
                    >Imagenología</a
                  >
                </li>
              </ul>

              <H level={5} size="md">Toma de Citología:</H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal11} class="text-blue-600 hover:underline"
                    >Imagenología</a
                  >
                </li>
              </ul>

              <H level={5} size="md">Lavado de Oidos:</H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal12} class="text-blue-600 hover:underline"
                    >Lavado de Oidos</a
                  >
                </li>
              </ul>
            </div>

            <div class="space-y-4">
              <H level={5} size="md">Prueba de Esfuerzo:</H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal13} class="text-blue-600 hover:underline"
                    >Prueba de Esfuerzo</a
                  >
                </li>
              </ul>

              <H level={5} size="md">
                Ecocardiograma Estrés con Ejercicio:
              </H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal14} class="text-blue-600 hover:underline"
                    >Ecocardiograma Estrés con Ejercicio</a
                  >
                </li>
              </ul>

              <H level={5} size="md">Holter del Ritmo:</H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal15} class="text-blue-600 hover:underline"
                    >Holter del Ritmo</a
                  >
                </li>
              </ul>
            </div>

            <div class="space-y-4">
              <H level={5} size="md">Colposcopia:</H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal16} class="text-blue-600 hover:underline"
                    >Colposcopia</a
                  >
                </li>
              </ul>

              <H level={5} size="md">Electrocardiograma:</H>
              <ul class="space-y-2 list-disc m-5">
                <li>
                  <a href={modal17} class="text-blue-600 hover:underline"
                    >Electrocardiograma</a
                  >
                </li>
              </ul>
            </div>

            <div class="col-span-full mb-8 text-start">
              <P size="lg">
                Si tiene alguna pregunta o necesita asistencia adicional, por
                favor no duden en contactarnos Estamos <a
                  href="/contact-us"
                  class="text-blue-600 hover:underline">aquí</a
                > para ayudarles en todo lo que necesitan.
              </P>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Abrir detalles imagenes -->
    <div
      id="openModal"
      class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-70"
    >
      <div class="bg-white rounded-lg max-w-4xl max-h-[90vh] w-[90%]">
        <div class="flex justify-between items-center p-4 border-b">
          <h2 id="modalTitle" class="text-xl font-semibold"></h2>
          <button
            id="modalCloseBtn"
            class="text-gray-600 hover:text-gray-900 text-3xl"
          >
            &times;
          </button>
        </div>
        <div class="p-4 flex justify-center items-center">
          <img
            id="modalImage"
            src=""
            alt="Imagen detallada"
            class="max-w-full max-h-[70vh] object-contain"
          />
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      const modal = document.getElementById("openModal");
      const modalImage = document.getElementById("modalImage");
      const modalTitle = document.getElementById("modalTitle");

      function openModal(imageHref, imageTitle) {
        modalImage.src = imageHref;
        modalTitle.textContent = imageTitle || "Imagen Detallada";
        modal.classList.remove("hidden");
        document.documentElement.style.overflow = "auto";
        document.body.style.overflow = "hidden";
      }

      function closeModal() {
        modal.classList.add("hidden");

        document.documentElement.style.overflow = "auto";
        document.body.style.overflow = "hidden";
      }

      const imagenes = document.querySelectorAll(
        'a[href$=".jpeg"], a[href$=".jpg"], a[href$=".png"]'
      );

      imagenes.forEach((imagen) => {
        imagen.addEventListener("click", function (e) {
          e.preventDefault();
          const imagenSrc = this.getAttribute("href");
          const imageTitle = this.textContent.trim();
          openModal(imagenSrc, imageTitle);
        });
      });

      document
        .getElementById("modalCloseBtn")
        .addEventListener("click", closeModal);
      modal.addEventListener("click", function (e) {
        if (e.target === modal) {
          closeModal();
        }
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && !modal.classList.contains("auto")) {
          closeModal();
        }
      });
    });
  </script>
</Layout>
