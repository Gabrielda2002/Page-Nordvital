---
import HeroSection from "@/components/common/HeroSection.astro";
import Layout from "../../layouts/Layout.astro";
import H from "@/components/ui/H.astro";
import P from "@/components/ui/P.astro";

//images
import img from "@/images/Header/USUARIOS_11zon.webp";
import img2 from "@/images/Usuarios/Asociacion-Usuaris/asociacion-usuarios.webp";

//icons
import ico1 from "@/images/Usuarios/Asociacion-Usuaris/ico-f1.svg";
import ico2 from "@/images/Usuarios/Asociacion-Usuaris/ico-f2.svg";
import ico3 from "@/images/Usuarios/Asociacion-Usuaris/ico-f3.svg";
import ico4 from "@/images/Usuarios/Asociacion-Usuaris/ico-f4.svg";
import ico5 from "@/images/Usuarios/Asociacion-Usuaris/ico-f5.svg";
import ico6 from "@/images/Usuarios/Asociacion-Usuaris/ico-f6.svg";
import { Image } from "astro:assets";
---

<Layout title="Asociación">
  <head>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
      rel="stylesheet"
    />
  </head>

  <main class="overflow-x-hidden bg-gray-100">
    <HeroSection title="Asociación de usuarios" backgroundImage={img} breadcrumb={[
      { label: "Inicio", link: "/" },
      { label: "Asociación", link: "/users/association" }
    ]} />

    <div
      class="container items-center mx-auto md:px-13 h-auto w-[90%] flex flex-col xl:flex-row"
    >
      <div class="rounded-3xl p-1 mb-4 w-full text-xl">
        <H level={1} size="xl" color="secondary" class="mb-4">
          La asociación de usuarios
        </H>
        <H level={3} size="lg"><em>¿Qué es?</em></H><br />
        <P color="muted" class="mb-4">
          La Junta de Usuarios en <span>NordVital IPS</span> es un órgano fundamental
          para asegurar que los servicios de salud prestados por la institución se
          ajusten a las necesidades y expectativas de sus usuarios.
        </P>
        <P color="muted">
          Este cuerpo consultivo y veedor está compuesto por representantes
          elegidos democráticamente entre la comunidad de usuarios, y su
          principal función es actuar como enlace entre los usuarios y la
          administración de la IPS.
        </P>
        <P color="muted">
          La Asociación de Usuarios tiene un papel clave en la representación de
          las inquietudes, quejas y sugerencias de los usuarios, garantizando
          así que sus voces sean escuchadas y tenidas en cuenta en la toma de
          decisiones relacionadas con la prestación de servicios de salud.
        </P>
      </div>

      <div class="w-[90%] md:w-2/3 h-auto">
        <Image
          src={img2}
          alt=""
          widths={[700, 1026, 1449, 1600, 1840, 2048]}
          sizes="(min-width: 1420px) 37.53vw, (min-width: 780px) calc(3.55vw + 455px), (min-width: 400px) calc(100vw - 24px), calc(16.25vw + 294px)"
        />
      </div>
    </div>

    <H level={1} size="lg" color="secondary" align="center" class="w-[80%] lg:w-[30%] leading-8 md:leading-10 mt-10 mx-auto">
          Principales funciones de una junta de usuarios en <em>NordVital IPS</em>
        </H>

    <div class="py-8">
      <section
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 w-[90%] max-w-5xl mx-auto"
      >
        <div
          class="flex flex-col items-center justify-center gap-4 p-6 border border-gray-200 hover:border-sky-400 rounded-lg shadow-lg hover:shadow-xl transition-all duration-500"
        >
          <img src={ico1.src} alt="Participación" class="w-16 h-16 mb-4" />
          <P size="lg" color="emphasis" align="center">
            Participación en la Planificación y Evaluación
          </P>
        </div>

        <div
          class="flex flex-col items-center justify-center gap-4 p-6 border border-gray-200 hover:border-sky-400 rounded-lg shadow-lg hover:shadow-xl transition-all duration-500"
        >
          <img src={ico2.src} alt="Representación" class="w-16 h-16 mb-4" />
          <P size="lg" color="emphasis" align="center">
            Representación de los Usuarios
          </P>
        </div>

        <div
          class="flex flex-col items-center justify-center gap-4 p-6 border border-gray-200 hover:border-sky-400 rounded-lg shadow-lg hover:shadow-xl transition-all duration-500"
        >
          <img src={ico3.src} alt="Mediación" class="w-16 h-16 mb-4" />
          <P size="lg" color="emphasis" align="center">
            Mediación de Conflictos
          </P>
        </div>

        <div
          class="flex flex-col items-center justify-center gap-4 p-6 border border-gray-200 hover:border-sky-400 rounded-lg shadow-lg hover:shadow-xl transition-all duration-500"
        >
          <img src={ico4.src} alt="Educación" class="w-16 h-16 mb-4" />
          <P size="lg" color="emphasis" align="center">
            Educación y Sensibilización
          </P>
        </div>

        <div
          class="flex flex-col items-center justify-center gap-4 p-6 border border-gray-200 hover:border-sky-400 rounded-lg shadow-lg hover:shadow-xl transition-all duration-500"
        >
          <img src={ico5.src} alt="Control" class="w-16 h-16 mb-4" />
          <P size="lg" color="emphasis" align="center">
            Control Social
          </P>
        </div>

        <div
          class="flex flex-col items-center justify-center gap-4 p-6 border border-gray-200 hover:border-sky-400 rounded-lg shadow-lg hover:shadow-xl transition-all duration-500"
        >
          <img src={ico6.src} alt="Promoción" class="w-16 h-16 mb-4" />
          <P size="lg" color="emphasis" align="center">
            Promoción de Derechos y Deberes
          </P>
        </div>
      </section>
    </div>
  </main>
</Layout>
