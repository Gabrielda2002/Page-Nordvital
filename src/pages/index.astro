---
import CorouselServices from "@/components/common/CarouselServices.astro";
import Layout from "../layouts/Layout.astro";
import H from "@/components/ui/H.astro";
import P from "@/components/ui/P.astro";

import dateBanner from "@/assets/index_icons/banner_agendar.webp?url";
import checkedIcon from "@/assets/index_icons/checked.svg?raw";
import Card from "@/components/Card.astro";
import CarouselHero from "@/components/common/CarouselHero.astro";
import CorouselInfinite from "@/components/common/CarouselInfinite.astro";
import Button from "@/components/common/Button.astro";

// img card headquarter
import img1 from "@/images/Sedes/Cucuta/Sede 6/SEDE-6-1.webp";
import img2 from "@/images/Sedes/Cucuta/Sede 6/SEDE-6-2.webp";
import img3 from "@/images/Sedes/Cucuta/Sede 6/SEDE-6-3.webp";
---

<Layout
  title="Nordvital IPS | Servicios médicos de calidad en Colombia"
  description="Nordvital IPS ofrece servicios médicos de alta calidad, con 11 sedes habilitadas y atención personalizada. Consulta médica, especialistas y más."
>

  <div>
    <div>
      <CarouselHero />

      <!-- ? text start -->
      <div
        aria-label="Introduccion"
        class="relative max-w-230 my-11 mx-auto mb-10"
        data-aos="fade-up"
        data-aos-duration="1000"
      >
        <div
          class="absolute inset-0 bg-linear-60-to-br from-nv-turquesa via-nv-verde-salud to-nv-azul-claro rounded-2xl p-0.75"
        >
          <div
            class="absolute inset-0 bg-linear-to-br from-nv-azul-oscuro/30 via-nv-turquesa/20 to-nv-verde-salud/30 rounded-2xl blur-sm"
          >
          </div>
        </div>
        <div
          class="relative grid grid-cols-1 p-6 lg:grid-cols-2 rounded-xl bg-white/95 backdrop-blur-sm gap-6 text-center md:text-left shadow-xl"
        >
          <div class="flex flex-col items-center justify-center gap-4">
            <H
              level={1}
              size="xl"
              class="text-center bg-linear-to-r from-nv-verde-salud to-nv-turquesa bg-clip-text text-transparent font-bold"
            >
              Una IPS comprometida con sus usuarios
            </H>
          </div>
          <div class="mx-auto w-[95%] md:w-full flex flex-col gap-3">
            <div
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-linear-to-r from-nv-verde-salud/20 to-nv-turquesa/20 border border-nv-verde-salud/30"
            >
              <span class="w-2 h-2 rounded-full bg-nv-verde-salud animate-pulse"
              ></span>
              <span class="text-lg font-bold text-nv-verde-salud"
                >Nordvital IPS</span
              >
            </div>
            <P clamp={2} align="left" class="text-nv-gris">
              Se destaca garantizando una atención médica de calidad, accesible
              y disponible para todos.
            </P>
            <div class="flex gap-2 mt-2">
              <span
                class="px-3 py-1 text-xs font-medium text-white rounded-full bg-nv-rojo-cta"
                >✓ Calidad</span
              >
              <span
                class="px-3 py-1 text-xs font-medium text-white rounded-full bg-nv-rojo-cta-dark"
                >✓ Accesible</span
              >
              <span
                class="px-3 py-1 text-xs font-medium text-white rounded-full bg-nv-rojo-cta-light"
                >✓ Disponible</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ? carousel inifinito -->
    <div class="mb-10" data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
      <CorouselInfinite />
    </div>

    <!-- ? section video -->
    <div
      aria-label="Video institucional"
      class="relative w-11/12 mx-auto mb-20"
      data-aos="fade-right"
      data-aos-duration="1000"
    >
      <div
        class="absolute inset-0 bg-linear-to-r from-nv-verde-salud/10 via-nv-turquoise/5 to-nv-azul/10 rounded-3xl"
      >
      </div>
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 p-6 lg:p-10">
        <div class="relative group">
          <div
            class="absolute -inset-1 bg-linear-to-r from-nv-verde-salud to-nv-turquesa rounded-2xl blur opacity-30 group-hover:opacity-50 transition-opacity duration-500"
          >
          </div>
          <div class="relative rounded-xl overflow-hidden shadow-2xl">
            <lite-youtube
              videoId="46G-4lTJoyk"
              videotitle="Video institucional Nordvital IPS"
              videoplay="autoplay"
              posterquality="maxresdefault"></lite-youtube>
          </div>
        </div>
        <div class="flex flex-col justify-center">
          <div class="inline-flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-nv-turquesa animate-pulse"
            ></span>
            <span
              class="text-sm font-medium text-nv-turquesa uppercase tracking-wider"
              >Conócenos</span
            >
          </div>
          <H level={2} size="2xl" class="mb-4">
            Sobre <span
              class="bg-linear-to-r from-nv-verde-salud to-nv-turquesa bg-clip-text text-transparent"
              >Nosotros</span
            >
          </H>
          <P clamp={2} class="mb-4 text-nv-gris">
            <span class="font-bold text-nv-azul-oscuro"
              >Nordvital IPS S.A.S</span
            >
            es una IPS de carácter privado que ofrece servicios de atención primaria
            y de complejidad media a sus usuarios a través de las EPS o de manera
            particular.
          </P>
          <P clamp={1} class="mb-6">
            Nos destacamos siempre por
            <span class="text-nv-verde-salud font-bold">nuestros valores.</span>
          </P>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
            <div
              class="flex items-center gap-2 p-3 rounded-xl bg-nv-verde-salud/10 border border-nv-verde-salud/20"
            >
              <div
                class="w-8 h-8 rounded-lg bg-nv-verde-salud/20 flex items-center justify-center"
                set:html={checkedIcon}
              />
              <span class="text-sm font-semibold text-nv-azul-oscuro"
                >Lealtad</span
              >
            </div>
            <div
              class="flex items-center gap-2 p-3 rounded-xl bg-nv-turquesa/10 border border-nv-turquesa/20"
            >
              <div
                class="w-8 h-8 rounded-lg bg-nv-turquesa/20 flex items-center justify-center"
                set:html={checkedIcon}
              />
              <span class="text-sm font-semibold text-nv-azul-oscuro"
                >Empatía</span
              >
            </div>
            <div
              class="flex items-center gap-2 p-3 rounded-xl bg-nv-azul/10 border border-nv-azul/20"
            >
              <div
                class="w-8 h-8 rounded-lg bg-nv-azul/20 flex items-center justify-center"
                set:html={checkedIcon}
              />
              <span class="text-sm font-semibold text-nv-azul-oscuro"
                >Gratitud</span
              >
            </div>
            <div
              class="flex items-center gap-2 p-3 rounded-xl bg-nv-azul-oscuro/10 border border-nv-azul-oscuro/20"
            >
              <div
                class="w-8 h-8 rounded-lg bg-nv-azul-oscuro/20 flex items-center justify-center"
                set:html={checkedIcon}
              />
              <span class="text-sm font-semibold text-nv-azul-oscuro"
                >Respeto</span
              >
            </div>
          </div>
          <div class="flex justify-start">
            <Button url="/aboutus/aboutus" variant="secondary" size="md">
              Conoce más sobre nosotros
            </Button>
          </div>
        </div>
      </div>
    </div>

    <!-- ? carousel services -->
    <div aria-label="Nuestros servicios" class="w-11/12 mx-auto mb-20" data-aos="fade-up" data-aos-duration="800" data-aos-delay="150">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-nv-turquesa/10 border border-nv-turquesa/20 mb-4">
          <span class="w-2 h-2 rounded-full bg-nv-turquesa animate-pulse"></span>
          <span class="text-sm font-medium text-nv-turquesa">Servicios</span>
        </div>
        <H level={2} size="2xl" class="mb-6" align="center">
          Nuestros <span
            class="bg-linear-to-r from-nv-verde-salud to-nv-turquesa bg-clip-text text-transparent"
            >Servicios</span
          >
        </H>
      </div>
      <CorouselServices />
    </div>

    <!-- ? date banner -->
    <div aria-label="date" class="relative w-full h-100 mb-20" data-aos="zoom-in" data-aos-duration="1000">
      <div
        class="w-full h-full bg-cover bg-center"
        style={`background-image: url(${dateBanner})`}
      >
        <div
          class="absolute inset-0 flex flex-col justify-center p-10 text-white"
        >
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/15 backdrop-blur-md border border-white/25 mb-4 w-fit">
            <span class="w-2 h-2 rounded-full bg-nv-turquesa animate-pulse"></span>
            <span class="text-sm font-medium text-white/90">Agenda tu cita</span>
          </div>
          <H level={2} size="2xl" class="mb-2" color="white" align="left">
            ¿Ya agendaste tu cita particular?
          </H>
          <P clamp={2} align="left" color="white" class="max-w-xl pb-3">
            Tú bienestar es nuestra prioridad. En Nordvital IPS, ofrecemos
            atención médica personalizada que se adapta a tus necesidades
            individuales.
          </P>
          <div class="flex justify-start">
            <Button
              url="https://api.whatsapp.com/send?phone=573174309873"
              variant="primary"
              target="_blank">Agendar cita</Button
            >
          </div>
        </div>
      </div>
    </div>

    <!-- ? headquarters section -->
    <div aria-label="headquarters" class="mb-20" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="200">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-nv-verde-salud/10 border border-nv-verde-salud/20 mb-4">
          <span class="w-2 h-2 rounded-full bg-nv-verde-salud animate-pulse"></span>
          <span class="text-sm font-medium text-nv-verde-salud">Sedes</span>
        </div>
        <H level={2} size="2xl" class="mb-6" align="center">
          Nuestras <span
            class="bg-linear-to-r from-nv-verde-salud to-nv-turquesa bg-clip-text text-transparent"
          >
            Sedes
          </span>
        </H>
        <P clamp={2} class="mb-6" align="center">
          Contamos actualmente con 11 sedes habilitadas, donde nos destacamos
          por nuestra excelente atención y cuidado hacia nuestros usuarios.
          <a
            href="/aboutus/headquarters"
            class="text-nv-verde-salud font-bold hover:text-nv-turquesa hover:underline"
            >¡Conoce tu sede más cercana!</a
          >
        </P>
      </div>
      <div>
        <Card
          title="SEDES 07:"
          address="CALLE 8 # 0-71 BARRIO LATINO"
          mapLink="https://maps.app.goo.gl/MsU4raTfftwrrgff7"
          images={[img1, img2, img3]}
          latitude={7.889777001722247}
          longitude={-72.49932596258395}
        />
      </div>
    </div>

    <!-- ? blog -->
    <!-- <div aria-label="Blog" class="mb-20">
      <div class="text-center">
        <H level={6} size="2xl" class="mb-3" align="center">
          Nuestro <span
            class="text-white bg-linear-to-l from-nordvital-secondary to-[#017bdedf] rounded-3xl"
          >
            Blog
          </span>
        </H>
        <P size="lg" class="mb-3" align="center">
          ¡Bienvenido al blog de <span class="font-bold"> Nordvital IPS</span>!
          Encuentra consejos sobre salud, bienestar y eventos. Únete para vivir
          de manera más saludable y equilibrada.
        </P>
      </div>
      <div class="flex justify-center">
        <script src="https://static.elfsight.com/platform/platform.js" async
        ></script>
        <div
          class="elfsight-app-1638870b-e6e4-4d40-9105-548fdcbad3ba"
          data-elfsight-app-lazy
        >
        </div>
      </div>
    </div> -->
  </div>
</Layout>
