---
import HeroSection from "@/components/common/HeroSection.astro";
import Layout from "@/layouts/Layout.astro";
import H from "@/components/ui/H.astro";
import P from "@/components/ui/P.astro";

//img
import sectionImg from "@/images/AboutUs/NOSOTROS.webp";
import Accordion from "@/components/common/Accordion.astro";

import docPdf from "@/pdf/politicas-datos/POLITICA-DE-DATOS.pdf?url";
---

<Layout
  title="Política de Tratamiento de Datos Personales | Nordvital IPS"
  description="Conoce nuestra política de protección y tratamiento de datos personales en Nordvital IPS. Cumplimos con la Ley 1581 de 2012 y el Decreto 1377 de 2013 para garantizar la privacidad y seguridad de tu información."
>
  <HeroSection
    title="Política de Tratamiento de Datos Personales"
    backgroundImage={sectionImg}
    breadcrumb={[
      { label: "Inicio", link: "/" },
      {
        label: "Política de Tratamiento de Datos Personales",
        link: "/data-policy",
      },
    ]}
  />
  <div class="flex flex-col justify-center items-center m-5">
    <div class="flex flex-col items-center w-1/2 space-y-4">
      <H level={4} size="2xl" color="primary">
        Política de Tratamiento de Datos Personales
      </H>
      <P align="justify" leading="relaxed">
        En <span class="font-bold text-nv-verde-salud">
          NORDVITAL IPS SAS</span
        >, reconocemos la importancia de proteger la privacidad y
        confidencialidad de los datos personales. En cumplimiento de la Ley 1581
        de 2012 y el Decreto 1377 de 2013, adoptamos una política para
        garantizar un manejo responsable y seguro de la información personal.
      </P>
    </div>

    <Accordion title="Política de datos" id="1">
      <div class="">
        <H level={4} size="md">Propósito:</H>
        <ul class="list-disc ml-5 mb-3">
          <li>Proteger la privacidad y derechos de los titulares.</li>
          <li>
            Asegurar que los datos se recolecten y procesen con consentimiento y
            fines legítimos.
          </li>
          <li>
            Implementar medidas para evitar accesos no autorizados o usos
            indebidos.
          </li>
          <li>
            Garantizar a los titulares derechos como acceso, rectificación,
            cancelación y oposición.
          </li>
        </ul>

        <H level={4} size="md">Ámbito de Aplicación:</H>
        <P class="mb-3">
          Aplica a todas las personas cuyos datos sean tratados por NORDVITAL
          IPS, incluyendo pacientes, empleados, proveedores y contratistas. Se
          cubren actividades como recolección, almacenamiento, uso, transmisión
          y supresión de datos, bajo normativas locales e internacionales.
        </P>

        <H level={4} size="md">Derechos de los Titulares:</H>
        <ul class="list-disc ml-5 mb-3">
          <li>Conocer, actualizar y rectificar sus datos.</li>
          <li>Solicitar prueba de autorización para el tratamiento.</li>
          <li>
            Revocar el consentimiento y solicitar la supresión de datos cuando
            no se cumplan principios legales.
          </li>
          <li>
            Presentar quejas ante la Superintendencia de Industria y Comercio.
          </li>
        </ul>

        <H level={4} size="md">Deberes de NORDVITAL IPS SAS:</H>
        <ul class="list-disc ml-5 mb-3">
          <li>Garantizar la seguridad y confidencialidad de los datos.</li>
          <li>
            Usar los datos solo con autorización y para las finalidades
            comunicadas.
          </li>
          <li>
            Implementar controles de seguridad para evitar adulteraciones o
            accesos no autorizados.
          </li>
        </ul>

        <H level={4} size="md">Mecanismos de Autorización:</H>
        <P class="mb-3">
          La autorización para el tratamiento de datos puede ser otorgada de
          forma escrita, telefónica o digital, asegurando siempre que los
          titulares estén informados sobre el uso de su información.
        </P>

        <H level={3} size="md">Finalidades del Tratamiento:</H>
        <ul class="list-disc ml-5 mb-3">
          <li>Comunicar servicios ofrecidos y novedades.</li>
          <li>Cumplir obligaciones legales y contractuales.</li>
          <li>Realizar evaluaciones de calidad y estudios internos.</li>
        </ul>

        <P class="mb-3">
          Para más información, consulta nuestra política completa en <a
            href={docPdf}
            class="font-bold text-nv-verde-salud"
            target="_blank">Tratamiento de datos personales</a
          >.
        </P>
      </div>
    </Accordion>
  </div>
</Layout>
