---
import HeroSection from "@/components/common/HeroSection.astro";
import Layout from "../layouts/Layout.astro";
import ContactServices from "@/components/content/ContactServices.astro";
import TabsContent from "@/components/common/TabsContent.astro";
import CardServOdonto from "@/components/common/CardServOdonto.astro";
import H from "@/components/ui/H.astro";
import P from "@/components/ui/P.astro";

// content
import { servicesMdEsp } from "@/content/services-md-esp";
import { servicesImgDiag } from "@/content/services-img-diag";
import Button from "@/components/common/Button.astro";
import CardManteSalud from "@/components/common/CardManteSalud.astro";

// svg icons
import img from "@/images/Services/SERVICIOS.jpg";

import odonIcon from "@/assets/services_icons/dental.svg?raw";
import medGeneralIcon from "@/assets/services_icons/stethoscope.svg?raw";
import labIcon from "@/assets/services_icons/microscope.svg?raw";
import imgDiagIcon from "@/assets/services_icons/report-medical.svg?raw";
import medEspIcon from "@/assets/services_icons/heartbeat.svg?raw";
import manSaIcon from "@/assets/services_icons/medicine-syrup.svg?raw";
import imgCardLab from "@/assets/services_icons/laboratorio/servicio__enfermeras.png";
// odontologia icons
import odontoIcon1 from "@/assets/services_icons/odontologia/odo-1.svg";
import odontoIcon2 from "@/assets/services_icons/odontologia/odo-2.svg";
import odontoIcon3 from "@/assets/services_icons/odontologia/odo-3.svg";
import odontoIcon4 from "@/assets/services_icons/odontologia/odo-4.svg";
import odontoIcon5 from "@/assets/services_icons/odontologia/odo-5.svg";
import odontoIcon6 from "@/assets/services_icons/odontologia/odo-6.svg";

// img mantenimiento de la salud
import manIcon1 from "@/assets/services_icons/manteSalud/mant-1.svg";
import manIcon2 from "@/assets/services_icons/manteSalud/mant-2.svg";
import { Image } from "astro:assets";

interface Tab {
  id: string;
  title: string;
  icon?: string;
}

const serviceTabs: Tab[] = [
  {
    id: "medicina-general",
    title: "Medicina General",
    icon: medGeneralIcon,
  },
  {
    id: "odontologia",
    title: "Odontología",
    icon: odonIcon,
  },
  {
    id: "laboratorio-clinico",
    title: "Laboratorio Clínico",
    icon: labIcon,
  },
  {
    id: "medicina-especializada",
    title: "Medicina Especializada",
    icon: medEspIcon,
  },
  {
    id: "imagenes-diagnosticas",
    title: "Imágenes Diagnósticas",
    icon: imgDiagIcon,
  },
  {
    id: "mantenimiento-salud",
    title: "Mantenimiento de la Salud",
    icon: manSaIcon,
  },
];
---

<Layout
  title="Servicios Médicos | Nordvital IPS - Atención médica integral"
  description="Nordvital IPS ofrece servicios médicos completos: medicina general, especializada, odontología, laboratorio clínico, imágenes diagnósticas y programas de mantenimiento de la salud. Atención de calidad para toda la familia."
>
  <div>
    <div>
      <HeroSection
        title="Servicios"
        backgroundImage={img}
        breadcrumb={[
          { label: "Inicio", link: "/" },
          { label: "Servicios", link: "/services" },
        ]}
      />
    </div>

    <div data-aos="fade-up" data-aos-duration="1000" data-aos-delay="100">
      <TabsContent tabs={serviceTabs}>
        <!-- ? medicina general -->
        <div data-tab-content="medicina-general">
          <div class="servicio__item-container">
            <div
              class="servicio__item-dscpn grid grid-cols-1 lg:grid-cols-[70%_30%] lg:gap-5"
            >
              <div class="space-y-4">
                <div class="flex items-center w-fit">
                  <div set:html={medGeneralIcon} />
                  <P size="lg" color="secondary" class="font-semibold">
                    Servicio
                  </P>
                </div>

                <H level={4} size="lg">Medicina General</H>
                <P align="justify" leading="relaxed" hyphens>
                  La medicina general representa el primer nivel de atención
                  médica.
                </P>
                <P align="justify" leading="relaxed" hyphens>
                  Los médicos y médicas generales son profesionales con
                  preparación académica para la prevención, detección,
                  tratamiento y seguimiento de enfermedades agudas y crónicas.
                  Tienen la capacidad de resolver problemas de salud de forma
                  transversal y de decidir la derivación a especialistas cuando
                  una patología se descompensa o lo requiere.
                </P>
              </div>

              <div>
                <ContactServices />
              </div>
            </div>
          </div>
        </div>

        <!-- ? Odontologia -->
        <div data-tab-content="odontologia">
          <div class="servicio__item-container">
            <div class="grid grid-cols-1 lg:grid-cols-[70%_30%] lg:gap-5">
              <div class="space-y-4">
                <div class="flex items-center">
                  <div set:html={odonIcon} />
                  <P size="lg" color="secondary" class="font-semibold">
                    Servicio
                  </P>
                </div>
                <H level={4} size="lg">Odontología</H>

                <P align="justify" leading="relaxed" hyphens>
                  La atención de consulta externa en odontología general,
                  incluye consultas iniciales y de control, esta enfocada en la
                  atención preventiva y curativa, realizando el tratamiento
                  clínicos bucales a pacientes con el fin de preservar su salud
                  bucal y brindando bienestar.
                </P>

                <P align="justify" leading="relaxed" hyphens>
                  La atención por odontología general, comienza con la fase de
                  higiene oral, en el cual se realiza el tratamiento preventivo
                  incluyendo educación en salud oral y según los hallazgos se
                  realiza tratamiento integral con la participación de
                  especialistas si el caso lo requiere.
                </P>
              </div>
              <div class="mb-3 lg:mb-0">
                <ContactServices />
              </div>
            </div>

            <div class="space-x-4 space-y-4 my-8">
              <H level={3} size="lg" align="center">Te Ofrecemos:</H>
              <div
                class="grid grid-cols-1 lg:grid-cols-3 justify-center m-auto items-center gap-7 w-[105%] md:w-[75%]"
              >
                <CardServOdonto
                  title="Cirugía maxilofacial"
                  icon={odontoIcon1}
                  content="Es una especialidad quirúrgica que se enfoca en el diagnóstico y tratamiento de infecciones relacionadas con la boca, mandíbula y estructuras faciales."
                />
                <CardServOdonto
                  title="Cirugía oral"
                  icon={odontoIcon2}
                  content="Hace referencia a cualquier procedimiento quirúrgico en la boca y la mandíbula o en las áreas circundantes."
                />
                <CardServOdonto
                  title="Rehabilitación oral"
                  icon={odontoIcon3}
                  content="Se encarga de restaurar la función y la estética de la boca mediante tratamientos como prótesis dentales, implantes y otros procedimientos."
                />
                <CardServOdonto
                  title="Periodoncia"
                  icon={odontoIcon4}
                  content="Es el diagnóstico, tratamiento y prevención de enfermedades que afectan las encías y las estructuras de soporte de los dientes."
                />
                <CardServOdonto
                  title="Odontología General"
                  icon={odontoIcon5}
                  content="Abarca el diagnóstico, tratamiento y prevención de enfermedades bucales comunes."
                />
                <CardServOdonto
                  title="Endodoncia"
                  icon={odontoIcon6}
                  content="Es la especialidad de la odontología que se centra en el tratamiento de los conductos radiculares."
                />
              </div>
            </div>
          </div>
        </div>

        <!-- ? Laboratorio Clínico -->
        <div data-tab-content="laboratorio-clinico">
          <div class="servicio__item-container">
            <div class="grid grid-cols-1 lg:grid-cols-[70%_30%] gap-5">
              <div class="space-y-4">
                <div class="flex items-center">
                  <div set:html={labIcon} />
                  <P size="lg" color="secondary" class="font-semibold">
                    Servicio
                  </P>
                </div>
                <H level={4} size="lg" class="mb-3">Laboratorio Clinico</H>
                <P align="justify" leading="relaxed" hyphens class="mb-3">
                  En NordVital IPS, entendemos que la precisión y la rapidez en
                  los resultados de los análisis clínicos son esenciales para un
                  diagnóstico médico efectivo y un tratamiento adecuado. Nuestro
                  Laboratorio Clínico se destaca por su compromiso con la
                  excelencia y la innovación, garantizando que cada prueba se
                  realice con los más altos estándares de calidad y utilizando
                  tecnología de punta.
                </P>
                <P align="justify" leading="relaxed" hyphens class="mb-3">
                  Contamos con un equipo de profesionales altamente capacitados
                  y dedicados, cuyo objetivo principal es brindar un servicio
                  confiable y seguro. Nuestra infraestructura está diseñada para
                  optimizar cada etapa del proceso, desde la recolección de
                  muestras hasta la entrega de resultados, asegurando así la
                  comodidad y tranquilidad de nuestros pacientes.
                </P>
              </div>
              <div class="mb-3 lg:mb-0">
                <ContactServices />
              </div>
            </div>

            <div class="mt-3 mb-3 lg:mb-0 lg:mt-0 space-y-4 my-8">
              <H level={5} align="center" class="mb-2">Te ofrecemos:</H>

              <div class="grid grid-cols-1 lg:grid-cols-5 gap-5">
                <div class="hover:scale-105 transition-all">
                  <CardServOdonto
                    title="Inmunoquímica"
                    content="Detectamos y medimos sustancias en la sangre para ayudar en el diagnóstico y monitoreo de diversas enfermedades."
                    showIcon={false}
                  />
                </div>
                <div class="hover:scale-105 transition-all">
                  <CardServOdonto
                    title="Inmunoserología"
                    content="Evaluamos la respuesta inmunológica del cuerpo frente a infecciones y enfermedades a través del análisis de sueros."
                    showIcon={false}
                  />
                </div>
                <div class="hover:scale-105 transition-all">
                  <CardServOdonto
                    title="Hematología"
                    content="Analizamos la sangre y sus componentes para diagnosticar condiciones como anemia, infecciones y trastornos hematológicos."
                    showIcon={false}
                  />
                </div>
                <div class="hover:scale-105 transition-all">
                  <CardServOdonto
                    title="Coagulación"
                    content="Examinamos los procesos de coagulación sanguínea para identificar trastornos que afectan la hemostasia."
                    showIcon={false}
                  />
                </div>
                <div class="hover:scale-105 transition-all">
                  <CardServOdonto
                    title="Microscopía"
                    content="Utilizamos técnicas microscópicas avanzadas para observar células y tejidos, proporcionando diagnósticos precisos y detallados."
                    showIcon={false}
                  />
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
              <div class="flex flex-col justify-center items-start space-y-4">
                <H level={4} size="md">
                  ¡Obtén tus Resultados de Laboratorio con <span
                    class="text-nv-turquesa">Nordvital IPS</span
                  >!
                </H>
                <P align="justify" leading="relaxed" hyphens>
                  Tu salud es nuestra prioridad. Ahora puedes acceder a tus
                  resultados de laboratorio de manera rápida y segura desde la
                  comodidad de tu hogar.
                </P>
                <p
                  class="text-base text-gray-700 text-justify hyphens-auto text-wrap-pretty leading-relaxed"
                >
                  Simplemente ingresa a nuestro portal en línea y obtén toda la
                  información que necesitas al instante.
                </p>
                <Button url="/users/laboratorios">Ver más</Button>
              </div>
              <div class="lg:flex hidden justify-center items-center">
                <Image
                  src={imgCardLab}
                  alt="img card laboratorio"
                  class="w-109.5 h-106"
                  widths={[300, 600, 900]}
                  sizes="(min-width: 1420px) 37.53vw, (min-width: 780px) calc(3.55vw + 455px), (min-width: 400px) calc(100vw - 24px), calc(16.25vw + 294px)"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- ? Medicina Especializada -->
        <div data-tab-content="medicina-especializada">
          <div class="servicio__item-containe r">
            <div class="grid grid-cols-1 lg:grid-cols-[70%_30%] gap-5">
              <div class="space-y-">
                <div class="flex items-center">
                  <div set:html={medEspIcon} />
                  <P size="lg" color="secondary" class="font-semibold">
                    Servicio
                  </P>
                </div>
                <H level={4} size="lg">Medicina Especializada</H>
                <P align="justify" leading="relaxed" hyphens class="mb-3">
                  Nordvital IPS tiene un modelo de atención basado en la
                  medicina familiar fundamentado en el abordaje integral del
                  paciente desde los aspectos biológicos, psicológicos y
                  sociales para modificar los factores de riesgo y creando una
                  cultura de compromiso para la promoción de la salud y
                  prevención de la enfermedad. Este enfoque hace eficiente el
                  proceso de atención y asegura la pertinencia de las remisiones
                  a otros niveles de atención.
                </P>
                <P align="justify" leading="relaxed" hyphens class="mb-3">
                  En este espacio encontrarás nuestras especialidades y
                  subespecialidades médicas enfocadas en la alta complejidad.
                  Nuestro enfoque integral involucra a un equipo
                  multidisciplinario de profesionales en áreas de la salud,
                  apoyados por la más avanzada tecnología.
                </P>
              </div>

              <div class="mb-3 lg:mb-0">
                <ContactServices />
              </div>
            </div>

            <div class="mt-3 mb-3 lg:mb-0 lg:mt-0 space-y-4 my-8">
              <H level={5} class="mb-2" align="center">Te ofrecemos:</H>

              <div
                class="grid grid-cols-1 lg:grid-cols-3 gap-7 w-[105%] md:w-[75%] mx-auto"
              >
                {
                  servicesMdEsp.map((s) => (
                    <div>
                      <CardServOdonto
                        title={s.title}
                        content={s.content}
                        icon={s.icon}
                        showIcon={true}
                      />
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- ? Imagenes Diagnósticas -->
        <div data-tab-content="imagenes-diagnosticas">
          <div class="servicio__item-container">
            <div class="grid grid-cols-1 lg:grid-cols-[70%_30%] gap-5">
              <div class="space-y-4">
                <div class="flex items-center">
                  <div set:html={imgDiagIcon} />
                  <P size="lg" color="secondary" class="font-semibold">
                    Servicio
                  </P>
                </div>

                <H level={3} size="lg">Imágenes Diagnósticas</H>
                <P align="justify" leading="relaxed" hyphens class="mb-3">
                  La complementación terapéutica es un apoyo esencial tanto para
                  la atención médica como odontológica, ya que proporciona
                  herramientas y recursos adicionales que facilitan un
                  diagnóstico preciso y una intervención efectiva.
                </P>
                <P align="justify" leading="relaxed" hyphens class="mb-3">
                  Este proceso incluye una variedad de ayudas paraclínicas,
                  tales como exámenes de laboratorio, estudios de imagen,
                  pruebas de función y otros métodos de evaluación que son
                  cruciales para confirmar los diagnósticos iniciales realizados
                  por los profesionales de la salud.
                </P>
              </div>
              <div>
                <ContactServices />
              </div>
            </div>

            <div class="mt-3 mb-3 lg:mb-0 lg:mt-0 space-y-4 my-8">
              <H level={5} align="center" class="mb-2"> Te ofrecemos: </H>
              <div
                class="grid grid-cols-1 lg:grid-cols-[30%_30%_30%] md:w-[75%] w-full gap-6 justify-center mx-auto"
              >
                {
                  servicesImgDiag.map((s) => (
                    <div>
                      <CardServOdonto
                        title={s.title}
                        content={s.content}
                        icon={s.icon}
                        showIcon={true}
                      />
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- ? Mantenimiento de la Salud -->
        <div data-tab-content="mantenimiento-salud">
          <div class="servicio__item-container">
            <div>
              <div>
                <div class="grid grid-cols-1 lg:grid-cols-[70%_30%] gap-5">
                  <div class="space-y-4">
                    <div class="flex items-center">
                      <div set:html={manSaIcon} />
                      <P size="lg" color="secondary" class="font-semibold">
                        Servicio
                      </P>
                    </div>
                    <H level={4} size="lg">Mantenimiento de la Salud</H>
                    <P align="justify" leading="relaxed" hyphens class="mb-3">
                      El nuevo Modelo de Atención en Salud hace énfasis en las
                      actividades de promoción de la salud y prevención de la
                      enfermedad.
                    </P>
                    <P align="justify" leading="relaxed" hyphens class="mb-3">
                      Por esta razón, Nordvital IPS cuenta con estrategias de
                      educación, cultura, adopción de estilos de vida saludables
                      y concienciación dirigidas a la población, incluyendo a
                      usuarios, familias y la sociedad en general.
                    </P>
                    <P align="justify" leading="relaxed" hyphens class="mb-3">
                      Dentro de los programas de Promoción y Prevención (P&P) se
                      incluyen actividades de acompañamiento, orientación y
                      capacitaciones prácticas sobre alimentación sana,
                      ejercicio adecuado, asistencia, manejo de medicamentos y
                      controles médicos.
                    </P>
                  </div>
                  <div class="mb-3 py-10 lg:mb-0">
                    <ContactServices />
                  </div>
                </div>
              </div>

              <div class="mt-3 mb-3 lg:mb-0 lg:mt-0 space-y-4 my-8">
                <H level={5} align="center" class="mb-2">Te ofrecemos:</H>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 h-full">
                  <div>
                    <CardManteSalud
                      uniqueId="1"
                      title="Ruta Integral de Atención en Salud para la Población Materno Perinatal"
                      description="Conjunto de procedimientos y servicios coordinados y diseñados para garantizar el cuidado integral de las mujeres embarazadas y sus recién nacidos"
                      image={manIcon1}
                    >
                      <ul
                        class="list-disc list-inside space-y-2 text-base text-gray-700 mb-3 text-justify hyphens-auto text-wrap-pretty leading-relaxed"
                      >
                        <li>Atención para el cuidado preconcepcional.</li>
                        <li>Interrupción voluntaria del embarazo.</li>
                        <li>Atención para el cuidado prenatal.</li>
                        <li>
                          Atención en salud para la valoracion, promocion y
                          apoyo de la lactancia materna.
                        </li>
                        <li>
                          Curso de preparación para la maternidad y la
                          paternidad.
                        </li>
                        <li>Atención en salud bucal.</li>
                        <li>
                          Atención para la promoción de la alimentación y
                          nutrición.
                        </li>
                        <li>Atención del puerperio.</li>
                        <li>Atención para el cuidado recién nacido.</li>
                        <li>Atención para el seguimiento al recién nacido.</li>
                        <li>Educación para la salud.</li>
                        <li>Servicio de Vacunación.</li>
                      </ul>
                    </CardManteSalud>
                  </div>
                  <div>
                    <CardManteSalud
                      uniqueId="2"
                      title="Mantenimiento de la salud"
                      description="Se refiere a las actividades y medidas destinadas prevenir enfermedades, detectar problemas de salud en etapas tempranas y promover una vida saludable."
                      image={manIcon2}
                    >
                      <ul
                        class="list-disc list-inside space-y-2 text-base text-gray-700 mb-3 text-justify hyphens-auto text-wrap-pretty leading-relaxed"
                      >
                        <li>
                          Atención en salud por pediatria, medicina general o
                          familiar, y enfermería para la primera infancia.
                        </li>
                        <li>
                          Atención en salud por medicina general, pediatria o
                          medicina familiar, y enfermería para la infancia.
                        </li>
                        <li>Servicio de Vacunación.</li>
                        <li>
                          Atención en salud por medicina general o familiar y
                          enfermería para la adolescencia.
                        </li>
                        <li>
                          Atención en salud por medicina general o familiar para
                          la juventud.
                        </li>
                        <li>
                          Atención en salud por medicina general o familiar para
                          la vejez.
                        </li>
                        <li>Detección temprana de cáncer de cuello uterino.</li>
                        <li>Detección temprana de cáncer de mama.</li>
                        <li>Detección temprana de cancer de prostata.</li>
                        <li>Detección temprana de cáncer de colon y recto.</li>
                        <li>
                          Atención para la planificación familiar y la
                          anticoncepción.
                        </li>
                        <li>Fortificación con micronutrientes en polvo.</li>
                        <li>Educación y comunicación para la salud.</li>
                      </ul>
                    </CardManteSalud>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </TabsContent>
    </div>
  </div>
</Layout>
